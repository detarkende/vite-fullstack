{
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "oxlint packages examples",
    "lint:fix": "oxlint packages examples --fix",
    "fmt:fix": "oxfmt packages examples README.md",
    "fmt:check": "oxfmt packages examples README.md --check",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "check": "pnpm lint && pnpm fmt:check && pnpm typecheck",
    "release": "pnpm run build && pnpm changeset publish",
    "prepare": "husky"
  },
  "packageManager": "pnpm@11.6.0",
  "devDependencies": {
    "@changesets/cli": "3.0.0-next.5",
    "@changesets/config": "4.0.0-next.5",
    "husky": "^9.1.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  }
}
